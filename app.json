{
  "expo": {
    "name": "UtilityKit",
    "slug": "utility-kit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "utilitykit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#D4960A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.utilitykit.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#D4960A"
      },
      "package": "com.utilitykit.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#D4960A"
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Doc Vault needs camera access to capture document photos.",
          "photosPermission": "Doc Vault needs photo library access to import images."
        }
      ],
      "expo-document-picker",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d7d1ecee-3c20-4c21-8d6e-351ddd33e9ef"
      }
    }
  }
}
